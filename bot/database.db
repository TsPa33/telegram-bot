import sqlite3

conn = sqlite3.connect("database.db")
cursor = conn.cursor()


def init_db():
    cursor.execute("""
    CREATE TABLE IF NOT EXISTS users (
        id INTEGER PRIMARY KEY AUTOINCREMENT,
        name TEXT,
        website TEXT,
        phone TEXT
    )
    """)

    cursor.execute("""
    CREATE TABLE IF NOT EXISTS brands (
        id INTEGER PRIMARY KEY AUTOINCREMENT,
        user_id INTEGER,
        brand TEXT
    )
    """)

    cursor.execute("""
    CREATE TABLE IF NOT EXISTS models (
        id INTEGER PRIMARY KEY AUTOINCREMENT,
        user_id INTEGER,
        model TEXT
    )
    """)

    conn.commit()


def add_user(data: dict):
    cursor.execute(
        "INSERT INTO users (name, website, phone) VALUES (?, ?, ?)",
        (data["name"], data["website"], data["phone"])
    )
    user_id = cursor.lastrowid

    for brand in data["brands"]:
        cursor.execute(
            "INSERT INTO brands (user_id, brand) VALUES (?, ?)",
            (user_id, brand)
        )

    for model in data["models"]:
        cursor.execute(
            "INSERT INTO models (user_id, model) VALUES (?, ?)",
            (user_id, model)
        )

    conn.commit()
